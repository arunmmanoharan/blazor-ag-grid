@page "/fetchdata-pagination"

<h1>Pagination</h1>

<p>
    This component demonstrates client-side pagination over an in-memory dataset
    of @rows.Count rows. Use the grid's page-size selector, or enable auto page
    size to fit the number of rows to the grid height. Columns are sortable,
    filterable and resizable.
</p>

@if (gridOpts == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="mb-2">
        <label>
            <input type="checkbox" checked="@autoPageSize" @onchange="OnAutoPageSizeChanged" />
            Auto page size (fit to grid height)
        </label>
    </div>

    @* @key recreates the grid when the auto-page-size toggle changes, since
       GridOptions are applied once when the grid is created. Page-size changes
       within a fixed set are handled live by ag-Grid's own selector. *@
    <AgGrid @key="gridKey" WidthStyle="100%" HeightStyle="400px" Options="gridOpts">
        <GridColumn Header="ID" Field="id" IsSortable="true" Width="90" />
        <GridColumn Header="Product" Field="product" IsSortable="true" IsFiltered="true" />
        <GridColumn Header="Category" Field="category" IsSortable="true" IsFiltered="true" />
        <GridColumn Header="Price" Field="price" IsSortable="true" />
        <GridColumn Header="In Stock" Field="inStock" IsSortable="true" />
    </AgGrid>
}

@code {
    private bool autoPageSize = false;
    private int gridKey = 0;

    private GridOptions gridOpts;
    private List<object> rows;

    protected override void OnInitialized()
    {
        rows = GenerateRows(100);
        BuildOptions();
    }

    private void BuildOptions()
    {
        gridOpts = new GridOptions
        {
            RowModelType = RowModelType.ClientSide,
            RowData = rows,
            EnablePagination = true,
            AnimateRows = true,
            DefaultColDef = new DefaultColDef { Resizable = true },

            // Auto page size computes the page size from the grid height, so the
            // fixed page size and its selector must be turned off in that mode.
            PaginationPageSize = autoPageSize ? (int?)null : 10,
            EnablePaginationAutoPageSize = autoPageSize ? true : (bool?)null,
            // The default page size (10) is included so it matches the selector
            // and ag-Grid does not warn (#94/#95).
            PaginationPageSizeSelector = autoPageSize ? (object)false : new[] { 5, 10, 20, 50 },
        };
    }

    private void OnAutoPageSizeChanged(ChangeEventArgs e)
    {
        autoPageSize = e.Value is bool b && b;
        BuildOptions();
        // Bump the key so Blazor disposes the current grid and creates a new one
        // with the updated pagination options.
        gridKey++;
    }

    private static List<object> GenerateRows(int count)
    {
        var categories = new[] { "Widgets", "Gadgets", "Gizmos", "Doohickeys" };
        var list = new List<object>(count);
        for (var i = 1; i <= count; i++)
        {
            list.Add(new
            {
                id = i,
                product = $"Product {i:D3}",
                category = categories[i % categories.Length],
                price = 5 + (i * 3) % 500,
                inStock = (i % 3) != 0,
            });
        }
        return list;
    }
}
